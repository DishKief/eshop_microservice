<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Eshop Activation Email</title>
    <meta charset="UTF-8" />
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  </head>
  <body>
    <h1>Hi <%= name %>,</h1>
    <p>
      Thank you for registering with Eshop. To activate your account, Please use
      the following activation code:
    </p>
    <h2><%= otp %></h2>
    <p>
      Please enter this code on the activation page within the next 5 minutes.
    </p>
    <p>
      If you did not register for a Eshop account, you can ignore this email.
    </p>
  </body>
</html>
